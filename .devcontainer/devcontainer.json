// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Node.js & TypeScript & Cloudflare & Claude Code Sandbox",
	// "image": "mcr.microsoft.com/devcontainers/typescript-node:24-bookworm",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"build": {
		"dockerfile": "Dockerfile",
		"args": {
			"TZ": "${localEnv:TZ:Europe/Stockholm}",
			"GIT_DELTA_VERSION": "0.18.2",
			"ZSH_IN_DOCKER_VERSION": "1.2.0"
		}
	},
	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
		"ghcr.io/devcontainers-extra/features/cloudflare-wrangler:1": {}
	},
	// appPort uses Docker's native -p port mapping (kernel-level, survives process restarts).
	// forwardPorts uses VS Code's application-level tunnel which can silently drop individual
	// ports when wrangler dev hot-reloads — causing "connection refused" from the host.
	"appPort": [
		// Workers
		8787, 8788,
		8976 // This is for wrangler login (OAuth callback)
	],

	"runArgs": [
		"--cap-add=NET_ADMIN",
		"--cap-add=NET_RAW",
		"--add-host=host.docker.internal:host-gateway"
		// --userns=host disables user namespace remapping so container UIDs map directly to host UIDs
		// This ensures files created by node (UID 1001) in the container are owned by lasse (UID 1001) on the host
		// "--userns=host"
	],
	// Configure tool-specific properties.

	"customizations": {
		"vscode": {
			"extensions": [
				"anthropic.claude-code",
				"eamodio.gitlens",
				"Vue.volar",
				"biomejs.biome",
				"cloudflare.cloudflare-workers-bindings-extension",
				"mhutchie.git-graph",
				"bradlc.vscode-tailwindcss"
			],
			"settings": {
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "biomejs.biome",
				"editor.codeActionsOnSave": {
					"source.fixAll.eslint": "explicit"
				},
				"terminal.integrated.defaultProfile.linux": "zsh",
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "bash",
						"icon": "terminal-bash"
					},
					"zsh": {
						"path": "zsh"
					}
				}
			}
		}
	},
	"remoteUser": "node",
	"mounts": [
		"source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
		"source=claude-code-config-${devcontainerId},target=/home/node/.claude,type=volume"
	],
	"containerEnv": {
		"NODE_OPTIONS": "--max-old-space-size=4096",
		"CLAUDE_CONFIG_DIR": "/home/node/.claude",
		"POWERLEVEL9K_DISABLE_GITSTATUS": "true",
		"LAUNCH_EDITOR": "code",
		"PLAYWRIGHT_MCP_CDP_ENDPOINT": "http://172.17.0.1:9222"
	},
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
	"workspaceFolder": "/workspace",
	"postCreateCommand": {
		// "initWorkspace": "sudo /usr/local/bin/init-workspace.sh $(whoami)"
	},
	"postStartCommand": {
		"initFirewall": "sudo /usr/local/bin/init-firewall.sh"
	},
	// Use 'postCreateCommand' to run commands after the container is created.
	//"postCreateCommand": "yarn install",

	"waitFor": "postStartCommand"
}
