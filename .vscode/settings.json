{
	"workbench.colorCustomizations": {
		"activityBar.background": "#24aa09e3",
		"activityBar.foreground": "#FFFFFF",
		"activityBar.inactiveForeground": "#A8D5A8",
		"activityBar.activeBorder": "#7FFF00",
		"activityBar.activeBackground": "#1e8a07c0"
	},
	"editor.defaultFormatter": "biomejs.biome",
	"editor.formatOnSave": true,
	"editor.codeActionsOnSave": {
		"source.fixAll.biome": "explicit",
		"source.organizeImports.biome": "explicit"
	},
	"biome.enabled": true,
	"typescript.tsdk": "node_modules/typescript/lib",
	"typescript.enablePromptUseWorkspaceTsdk": true,
	"vitest.workspaceConfig": "./vitest.workspace.ts",
	"vitest.configSearchPatternExclude": "{**/node_modules/**,**/.git/**}"
}
