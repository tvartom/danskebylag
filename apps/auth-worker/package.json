{
	"name": "@repo/auth-worker",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts"
		}
	},
	"scripts": {
		"dev": "wrangler dev --port 8788 --ip 0.0.0.0 --inspector-port 9230 --persist-to ../../.wrangler/state",
		"build": "wrangler deploy --dry-run --outdir=dist",
		"deploy:production": "wrangler deploy",
		"generate:types": "wrangler types",
		"typecheck": "wrangler types && tsc --noEmit"
	},
	"dependencies": {
		"@repo/shared": "workspace:*"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260317.1",
		"@repo/tsconfig": "workspace:*",
		"typescript": "^5.9.3",
		"wrangler": "^4.78.0"
	}
}
