{
	"name": "@repo/api-worker",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wrangler dev --port 8787 --ip 0.0.0.0 --inspector-port 9229 --persist-to ../../.wrangler/state",
		"build": "wrangler deploy --dry-run --outdir=dist",
		"deploy:production": "wrangler deploy",
		"generate:types": "wrangler types",
		"typecheck": "wrangler types && tsc --noEmit"
	},
	"dependencies": {
		"@repo/database": "workspace:*",
		"@repo/shared": "workspace:*",
		"drizzle-orm": "^1.0.0-beta"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260317.1",
		"@repo/auth-worker": "workspace:*",
		"@repo/tsconfig": "workspace:*",
		"typescript": "^5.9.3",
		"wrangler": "^4.78.0"
	}
}
