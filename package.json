{
	"name": "cloudflare-monorepo",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"dev:kill": "pkill -f '[t]urbo|[w]rangler|[n]uxt' || true",
		"build": "turbo run build",
		"deploy:production": "turbo run deploy:production",
		"check": "biome check --write .",
		"db:generate": "pnpm --filter @repo/database db:generate",
		"db:migrate:local": "pnpm --filter @repo/database db:migrate:local",
		"db:migrate:remote": "pnpm --filter @repo/database db:migrate:remote",
		"db:studio": "pnpm --filter @repo/database db:studio",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"generate:types": "turbo run generate:types",
		"typecheck": "turbo run typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@playwright/cli": "^0.1.1",
		"@vitest/coverage-v8": "^4.0.18",
		"turbo": "^2.8.12",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"wrangler": "^4.78.0"
	},
	"packageManager": "pnpm@10.32.1",
	"engines": {
		"node": ">=24.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"esbuild",
			"sharp",
			"workerd",
			"better-sqlite3"
		],
		"overrides": {
			"zod": "^4.3.6"
		}
	}
}
